flowchart TB
    Start(["Start"]) --> Sub1["roundNum = 1 
ASCIIBoard = 3x3 
NumRange = 1-3 inclusive
ButtonA = Red 
ButtonB = Green 
ButtonX = Blue 
ButtonY = Yellow 
UserDiceRoll = 0 
SwiftbotDiceRoll = 0 
UserScore = 0 
SwiftbotScore = 0"]
    GameOver1{"is UserDiceRoll > SwiftbotDiceRoll?"} -- Yes --> Sub3@{ label: "User's Turn" }
    Sub3 --> Sub4a["Check Win/Draw<br>Conditions"]
    Sub6["Maintain Log & Update Scoreboard"] --> Sub7["Play Again/Quit<br>Options"]
    Sub7 --> PlayAgain{"Play Again?"}
    PlayAgain -- No --> End(["End"])
    n1["welcome screen & registration"] --> Sub2["Generate & Roll Dice"]
    GameOver1 -- No --> n2@{ label: "SwiftBot's Turn" }
    PlayAgain -- yes --> Start
    Sub1 --> n1
    Sub2 --> GameOver1
    n2 --> Sub4a
    Sub4a --> GameOver2["finish round"]
    GameOver2 --> n3["RoundNum = RoundNum + 1"]
    n3 --> Sub6

